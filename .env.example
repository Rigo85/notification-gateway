# Servidor
NODE_ENV=development
PORT=8090
HOST=0.0.0.0
LOG_LEVEL=info

# Base de datos
DATABASE_URL=postgres://postgres:dev@localhost:5433/notification_gateway

# Worker (poner true para correr solo la API, p.ej. en tests)
WORKER_DISABLED=false

# true si corre detrás de un reverse proxy (usa X-Forwarded-For como IP real)
TRUST_PROXY=false

# Panel /admin — obligatorio en producción (openssl rand -hex 32)
SESSION_SECRET=

# Provider SMS: 'fake' (desarrollo, no envía nada) o 'goip' (equipo real)
SMS_PROVIDER=fake

# GOIP — solo los usa el provider goip
GOIP_BASE_URL=http://IP_DEL_GOIP
GOIP_USER=usuario
GOIP_PASSWORD=contraseña

# Destinatarios de alertas internas del gateway, separados por coma.
# En producción debe coincidir con el destinatario operativo de Atalaya.
SYSTEM_ALERT_RECIPIENTS=
